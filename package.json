{
  "name": "@open-model-contracts/server",
  "version": "0.1.0",
  "type": "module",
  "description": "Constitutional governance for AI model execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "mcp",
    "governance",
    "contracts",
    "ai",
    "agents",
    "model-context-protocol"
  ],
  "author": "Open Model-Contracts Contributors",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "build:informant": "tsc --project tsconfig.informant.json",
    "dev": "tsc --watch",
    "test": "echo \"Tests coming soon\"",
    "prepublishOnly": "npm run build",
    "bridge:install": "npm install --prefix server/bridge",
    "bridge:build": "npm run build --prefix server/bridge",
    "bridge:start": "npm run start --prefix server/bridge",
    "bridge:dev": "npm run dev --prefix server/bridge",
    "gen:schema": "tsx scripts/export-json-schema.ts",
    "check:schema": "npm run gen:schema && git diff --exit-code spec/json-schema/",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/luaparse": "^0.2.13",
    "chokidar": "^5.0.0",
    "luaparse": "^0.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-model-contracts/server.git"
  }
}
